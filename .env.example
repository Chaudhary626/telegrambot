# ──────────────────────────────────────────────
# Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────

# ── Telegram Bot Settings ──
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_user_id

# ── MySQL Database Settings ──
DB_HOST=srv1731.hstgr.io
DB_PORT=3306
DB_USER=u602666777_admin
DB_PASSWORD=your_database_password
DB_NAME=u602666777_telegram

# ── Stream API Settings ──
# Get API_ID and API_HASH from https://my.telegram.org → API Development Tools
API_ID=12345678
API_HASH=your_api_hash_here

# Secret key for protecting stream URLs (make this random and long)
STREAM_SECRET=change_this_to_a_random_string_like_xK9mP2qR7vL4nW8

# Your deployed Stream API URL on Render
# (Set this AFTER deploying stream_api.py as a Render service)
STREAM_API_URL=https://animegalaxyhub-stream.onrender.com

# Your website domain for CORS (comma separated, no spaces)
ALLOWED_ORIGINS=https://animegalaxyhub.com,http://localhost
